{
  "DisasterRefresh": {
    "CacheDuration": "00:10:00",
    "BackgroundRefreshInterval": "00:05:00",
    "WarmCacheOnStartup": true,
    "MaxHealthyStaleness": "00:30:00"
  },
  "NationalWeatherService": {
    "Enabled": true,
    "BaseUrl": "https://api.weather.gov",
    "UserAgent": "DisasterTracker.Api/1.0 (contact@example.com)",
    "TimeoutSeconds": 20
  },
  "Fema": {
    "Enabled": true,
    "BaseUrl": "https://www.fema.gov/api/open/v2/",
    "TimeoutSeconds": 20,
    "ActiveWindowDays": 365,
    "MaxRecords": 250
  },
  "Usgs": {
    "Enabled": true,
    "BaseUrl": "https://earthquake.usgs.gov/",
    "TimeoutSeconds": 20,
    "MinimumMagnitude": 1.5,
    "MinimumSignificance": 50
  },
  "Eonet": {
    "Enabled": true,
    "BaseUrl": "https://eonet.gsfc.nasa.gov/api/v3/",
    "TimeoutSeconds": 20,
    "MaxRecords": 250
  },
  "ZipCodeLookup": {
    "BaseUrl": "https://api.zippopotam.us/",
    "TimeoutSeconds": 15,
    "CacheDuration": "24:00:00"
  },
  "ZipBoundary": {
    "Enabled": true,
    "BaseUrl": "https://tigerweb.geo.census.gov/arcgis/rest/services/TIGERweb/tigerWMS_Current/MapServer/2/",
    "TimeoutSeconds": 20
  },
  "SupplyImpact": {
    "ResourceProfilePath": "Data/strategic-resource-profiles.json"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
